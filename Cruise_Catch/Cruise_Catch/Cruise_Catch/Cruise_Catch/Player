using Microsoft.Xna.Framework;
using Microsoft.Xna.Framework.Audio;
using Microsoft.Xna.Framework.Content;
using Microsoft.Xna.Framework.GamerServices;
using Microsoft.Xna.Framework.Graphics;
using Microsoft.Xna.Framework.Input;
using Microsoft.Xna.Framework.Media;
using System;
using System.Collections.Generic;
using System.Linq;
class Player
{
    enum PlayerState
    {
        standing,
        walking,
        falling,
        jumping,
        dead
    }
    Rectangle rec;
    Rectangle source;
    Texture2D spriteSheet;
    int runningSpeed;
    int currentFallingSpeed;
    PlayerState currentState;

    public Player(Rectangle rec, Rectangle source, Texture2D spriteSheet, int runningSpeed, int currentFallingSpeed)
    {
        this.rec = rec;
        this.source = source;
        this.spriteSheet = spriteSheet;
        this.runningSpeed = runningSpeed;
        this.currentFallingSpeed = currentFallingSpeed;
        currentState = PlayerState.standing;
    }

    public void determineState()
    {
        //if both vertical (falling) is 0 and horizontal (running) is 0, then the player is in rest
        if (currentFallingSpeed == 0 && runningSpeed == 0)
        {
            currentState = PlayerState.standing;
        }
        //if falling is negative, the player is jumping
        if (currentFallingSpeed < 0)
        {
            currentState = PlayerState.jumping;
        }
        //if falling is positive, the player is falling
        if (currentFallingSpeed > 0)
        {
            currentState = PlayerState.falling;
        }
        //if there is no vertical speed, but horizontal speed is not zero, the player is running.
        if (currentFallingSpeed == 0 && runningSpeed != 0)
        {
            currentState = PlayerState.walking;
        }
    }
    public void assignSprite()
    {
        switch (currentState)
        {
            case PlayerState.standing:
                source = new Rectangle(0, 0, 50, 50);
                break;
            case PlayerState.walking:
                source = new Rectangle(50, 0, 50, 50);
                break;
            case PlayerState.falling:
                source = new Rectangle(100, 0, 50, 50);
                break;
            case PlayerState.jumping:
                source = new Rectangle(150, 0, 50, 50);
                break;
            default:
                source = new Rectangle(200, 0, 50, 50);
                break;
        }
    }
}

